---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import TravelGlobe from "../../components/TravelGlobe.astro";
import { blogConfig } from "../../blogConfig";
import "../../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{blogConfig.title} - Nishkal Rao</title>
    <meta name="description" content={blogConfig.description} />
  </head>
  <body class="bg-page transition-colors duration-300">
    <Header />
    
    <main class="pt-0"> <section class="group relative w-full h-[85vh] overflow-hidden">
        <div class="absolute inset-0 z-0">
          <TravelGlobe trips={blogConfig.trips} />
        </div>
        
        <div class="absolute inset-0 z-10 flex flex-col items-center justify-center pointer-events-none transition-opacity duration-700 ease-in-out group-hover:opacity-0">
          <h1 class="text-6xl md:text-8xl font-bold tracking-tight text-center drop-shadow-2xl" style="font-family: var(--heading-font); color: rgba(var(--text-color),1);">
            Living the Dream
          </h1>
          <p class="mt-4 text-xl md:text-2xl drop-shadow-md text-center" style="font-family: var(--body-font); color: rgba(var(--text-color),0.9);">
            Exploring the world, one coordinate at a time.
          </p>
        </div>
      </section>

      <section class="max-w-6xl mx-auto px-6 py-24">
        <h2 class="text-4xl font-bold mb-12 text-center" style="font-family: var(--heading-font); color: rgba(var(--text-color),1);">
          Latest Expeditions
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {blogConfig.trips.map(trip => (
            <a href={`/blog/trip/${trip.id}`} class="group/card relative w-full h-[450px] rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2 border card-surface isolate block">
              
              <img 
                src={trip.coverImage} 
                alt={trip.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover/card:scale-105 -z-20"
              />
              
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent -z-10"></div>

              <div class="absolute inset-0 p-8 flex flex-col justify-end">
                <span class="inline-block px-4 py-1.5 mb-4 text-xs font-semibold rounded-full tracking-wider text-white w-max shadow-md" style={`background: linear-gradient(to right, ${trip.arcColors}, ${trip.arcColors[1]})`}>
                  {trip.date}
                </span>
                <h3 class="text-4xl font-bold text-white mb-3 drop-shadow-md" style="font-family: var(--heading-font);">
                  {trip.title}
                </h3>
                <p class="text-white/80 flex items-center gap-2 group-hover/card:text-white transition-colors" style="font-family: var(--body-font); font-size: 1.1rem;">
                  View Gallery & Stories <span class="transition-transform group-hover/card:translate-x-1">&rarr;</span>
                </p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

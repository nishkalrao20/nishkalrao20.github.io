---
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { blogConfig } from '../../../blogConfig';
import '../../../styles/global.css';

// 1. Generate paths for all trips defined in blogConfig.ts
export async function getStaticPaths() {
  return blogConfig.trips.map(trip => ({
    params: { tripId: trip.id },
    props: { trip },
  }));
}

const { trip } = Astro.props;

// 2. Fetch all global markdown posts
const allPosts = await Astro.glob('../../../contents/blog/*.md');

const getSlug = (path) => {
  const fileName = path.split('/').pop();
  return fileName ? fileName.replace('.md', '') : '';
};

// 3. Filter only the posts assigned to this specific trip
const tripPosts = allPosts.filter(post => trip.postSlugs.includes(getSlug(post.file)));

// Sort by date descending (newest first)
tripPosts.sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{trip.title} - Nishkal Rao</title>
    <meta name="description" content={`Travel journal and photography from ${trip.title}`} />
  </head>
  <body class="bg-page transition-colors duration-300">
    <Header />
    
    <main class="page-content min-h-screen">
      <section class="max-w-6xl mx-auto px-6 py-12">
        <div class="flex flex-col items-center text-center mb-16">
          <span class="inline-block px-4 py-1.5 mb-4 text-sm font-semibold rounded-full tracking-wider text-white shadow-sm" style={`background: linear-gradient(to right, ${trip.arcColors}, ${trip.arcColors[1]})`}>
            {trip.date}
          </span>
          <h1 class="text-5xl md:text-6xl font-bold mb-4" style="font-family: var(--heading-font); color: rgba(var(--text-color),1);">
            {trip.title}
          </h1>
          <a href="/blog" class="text-sm text-muted hover:text-[var(--accent-color)] transition-colors underline underline-offset-4" style="font-family: var(--body-font);">
            &larr; Back to World Map
          </a>
        </div>

        {tripPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {tripPosts.map(post => {
              const slug = getSlug(post.file);
              return (
                <a href={`/blog/${slug}`} class="group flex flex-col bg-card rounded-2xl overflow-hidden border card-surface shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                  
                  {post.frontmatter.coverImage ? (
                    <div class="w-full h-56 overflow-hidden">
                      <img 
                        src={post.frontmatter.coverImage} 
                        alt={post.frontmatter.title} 
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                      />
                    </div>
                  ) : (
                    <div class="w-full h-56 bg-[rgba(var(--muted-bg-rgb),1)] flex items-center justify-center">
                      <span class="text-muted">No Image</span>
                    </div>
                  )}
                  
                  <div class="p-6 flex flex-col flex-1">
                    <time class="text-xs text-muted mb-2 font-semibold uppercase tracking-wider" style="font-family: var(--body-font);">
                      {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                    </time>
                    <h3 class="text-2xl font-bold mb-3 leading-tight group-hover:text-[var(--accent-color)] transition-colors" style="font-family: var(--heading-font); color: rgba(var(--text-color),1);">
                      {post.frontmatter.title}
                    </h3>
                    <p class="text-muted text-sm leading-relaxed mb-4 flex-1" style="font-family: var(--body-font);">
                      {post.frontmatter.description}
                    </p>
                    <span class="text-sm font-semibold text-[var(--accent-color)] group-hover:translate-x-1 transition-transform inline-block w-max">
                      Read Post &rarr;
                    </span>
                  </div>
                </a>
              )
            })}
          </div>
        ) : (
          <div class="text-center py-20 text-muted italic" style="font-family: var(--body-font);">
            Content for this expedition is currently being drafted.
          </div>
        )}
      </section>
    </main>
    <Footer />
  </body>
</html>
